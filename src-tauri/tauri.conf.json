{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetTycoon",
  "version": "0.3.1",
  "identifier": "cloud.pavlicek.nettycoon",
  "build": {
    "frontendDist": "../dist-game",
    "beforeDevCommand": "npm run prepare-dist",
    "beforeBuildCommand": "npm run prepare-dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NetTycoon",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$HOME/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "nsis"],
    "category": "Game",
    "copyright": "© 2026 Míra Pavlíček",
    "shortDescription": "Česká ISP simulační hra",
    "longDescription": "NetTycoon je simulační hra, ve které rozjíždíš vlastního poskytovatele internetu v českém městě. Staví datacentra, pokládej kabely, podepisuj kontrakty, řeš incidenty a konkurenci.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  }
}
